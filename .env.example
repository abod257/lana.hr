# =====================================================
# HRMS & ESS Portal - Environment Configuration
# Copy to .env and fill in actual values
# =====================================================

# Application
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="HRMS Portal"

# Database (PostgreSQL)
DATABASE_URL="postgresql://hrms_user:hrms_password@localhost:5432/hrms_portal?schema=public"

# JWT Authentication
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production-min-32-chars"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Session
SESSION_SECRET="your-session-secret-change-this-in-production-min-32-chars"
SESSION_COOKIE_NAME="hrms_session"
SESSION_MAX_AGE=604800

# Encryption (for sensitive data)
ENCRYPTION_KEY="your-32-byte-encryption-key-here"

# Email (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM_NAME="HRMS Portal"
SMTP_FROM_EMAIL="noreply@company.com"

# SMS Provider (e.g., Twilio, Unifonic)
SMS_PROVIDER="unifonic"
SMS_API_KEY="your-sms-api-key"
SMS_FROM="HRMS"

# File Upload
UPLOAD_MAX_SIZE="10485760" # 10MB
UPLOAD_DIR="./public/uploads"
ALLOWED_FILE_TYPES="pdf,doc,docx,jpg,jpeg,png"

# Logging
LOG_LEVEL="info"
LOG_FILE="./logs/app.log"

# Rate Limiting
RATE_LIMIT_WINDOW="900000" # 15 minutes
RATE_LIMIT_MAX="100"

# CORS
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# 2FA
TWO_FACTOR_ISSUER="HRMS Portal"

# Audit Logs
AUDIT_LOG_RETENTION_DAYS="365"

# Default Admin (for seeding)
DEFAULT_ADMIN_EMAIL="admin@company.com"
DEFAULT_ADMIN_PASSWORD="Admin@123456"
